# ─────────────────────────────────────────────────────────────
# Nebula Code – Backend environment variables
# Copy this file to .env and fill in every value.
# ─────────────────────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development

# Session
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=replace_with_64_byte_random_hex_string

# GitHub OAuth App
# Create at: https://github.com/settings/developers → "OAuth Apps" → "New OAuth App"
#   Homepage URL        : http://localhost:5173
#   Authorization callback URL: http://localhost:3001/auth/github/callback
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
GITHUB_CALLBACK_URL=http://localhost:3001/auth/github/callback

# Frontend origin (used for CORS and post-login redirect)
FRONTEND_URL=http://localhost:5173

# URL the backend redirects to after a successful login
# The frontend should have a /auth/callback route that reads ?user= or simply
# renders the authenticated UI (session cookie is already set at this point).
FRONTEND_CALLBACK_URL=http://localhost:5173/auth/callback
