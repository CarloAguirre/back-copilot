# ─────────────────────────────────────────────────────────────
# Nebula Code – Backend environment variables
# Copy this file to .env and fill in every value.
# ─────────────────────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development

# Public URL of this backend (used to build authUrl in POST /auth/session)
BACKEND_URL=https://back-copilot.onrender.com

# JWT signing + GitHub token encryption key
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_byte_random_hex_string

# GitHub OAuth App credentials
# Create at: https://github.com/settings/developers → OAuth Apps → New OAuth App
#   Homepage URL              : https://chatgpt.com
#   Authorization callback URL: https://back-copilot.onrender.com/auth/github/callback
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
GITHUB_CALLBACK_URL=https://back-copilot.onrender.com/auth/github/callback

# CORS – origin allowed to call the API (* for ChatGPT Canvas)
FRONTEND_URL=*

# PostgreSQL connection string (Render provides this automatically)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Human-readable alias for GET /agent/current/:alias (e.g. "copilot-plus-2")
# Auto-assigned to any AgentSession created while this is set.
AGENT_ALIAS=copilot-plus-2

# Secret key for agent-facing endpoints (POST /agent/workspaces/:id/actions, etc.)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AGENT_API_KEY=replace_with_32_byte_random_hex_string

# GitHub webhook secret – set when creating the webhook on each repo
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must match the secret value used in POST /workspaces → ensureWebhook
GITHUB_WEBHOOK_SECRET=replace_with_32_byte_random_hex_string
